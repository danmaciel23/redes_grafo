        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Law enforcement personnel (who may include, in addition to law enforcement officers and agents, attormeys for the government, attorney support staff, agency personnel assisting the government in this investigation, and outside technical experts under government control) are authorized to review the ESI contained on the Subject Items for evidence, fruits, and instrumentalities of violations of Title 18, United States Code, Sections 1591 (sex trafficking of minors), and 371 (sex trafficking conspiracy) (the \"Subject Offenses\") described as follows:"
                    }
                ]
            },
            "bbox": [
                125,
                523,
                869,
                627
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Any documents or communications with or regarding victims or potential victims of the Subject Offenses;"
                    }
                ]
            },
            "bbox": [
                125,
                639,
                864,
                676
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Any photographs of victims or potential victims of the Subject Offenses;"
                    }
                ]
            },
            "bbox": [
                179,
                687,
                792,
                707
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3.Any nude, partially nude, or sexually suggestive photographs of individuals who appear to be teenage girls, or younger;"
                    }
                ]
            },
            "bbox": [
                124,
                718,
                862,
                755
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Records, data, or other items that evidence ownership, control, or use of, or access to the Subject Items, including, but not limited to access history data, historical location data, configuration files,saved usermames and passwords,， user profiles,e-mail contacts,and photographs;"
                    }
                ]
            },
            "bbox": [
                124,
                765,
                864,
                802
            ]
        },
        {
            "type": "page_footnote",
            "content": {
                "page_footnote_content": [
                    {
                        "type": "text",
                        "content": "1 To the extent that the Subject Items contain any SD cards or other removable storage media, the description of each such item encompasses those SD cards and other media."
                    }
