                467
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "WHEREAS the applicant has certified that the information likely to be obtained from the Requested Pen-Trap is relevant to an ongoing criminal investigation conducted by the Federal Bureau of Investigation (the \"Investigating Agency\") of FNU LNU and others known and unknown in connection with possible violations of 21 U.S.C. 8 1591."
                    }
                ]
            },
            "bbox": [
